# 1. CONEXÃO COM O SUPABASE (Obrigatório)
# Encontre no menu Project Settings -> API do painel do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui
